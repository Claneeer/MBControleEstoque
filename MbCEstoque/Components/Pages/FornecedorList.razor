@page "/fornecedores"
@using MbCEstoque.Models
@using MbCEstoque.Services.Interfaces
@inject IFornecedorService fornecedorService
@inject IDialogService dialogService
@inject ISnackbar Snackbar

<PageTitle>Fornecedores</PageTitle>
<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h5">
                Fornecedores
            </MudText>

            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Gerencie os fornecedores cadastrados no sistema de estoque.
            </MudText>
        </div>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AbrirNovoAsync">
            Novo Fornecedor
        </MudButton>
    </MudStack>
</MudPaper>
<MudDataGrid T="Fornecedor"
             Items="@_fornecedoresFiltrados"
             Loading="@_carregando"
             Dense="true"
             Hover="true"
             Bordered="true"
             Striped="true"
             Filterable="false"
             SortMode="SortMode.Multiple"
             RowsPerPage="10"
             Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Lista de Fornecedores</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      @bind-Value="_busca"
                      Placeholder="Buscar por razão social, CNPJ, e-mail ou telefone..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Clearable="true"
                      Class="mt-0"
                      Style="min-width: 360px;" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
        <PropertyColumn Property="x => x.RazaoSocial" Title="Razão Social" Sortable="true" />
        <PropertyColumn Property="x => x.CNPJ" Title="CNPJ" Sortable="true" />
        <PropertyColumn Property="x => x.Email" Title="E-mail" Sortable="true" />
        <PropertyColumn Property="x => x.Telefone" Title="Telefone" Sortable="false" />
        <PropertyColumn Property="x => x.Endereco" Title="Endereço" Sortable="false" />

        <TemplateColumn Title="Status" Sortable="false" Filterable="false">
            <CellTemplate>
                @if (context.Item.Ativo)
                {
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">
                        Ativo
                    </MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Size="Size.Small">
                        Inativo
                    </MudChip>
                }
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Ações" Sortable="false" Filterable="false" StickyRight="true">
            <CellTemplate>
                <MudTooltip Text="Editar fornecedor">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Warning"
                                   Size="Size.Small"
                                   OnClick="@(() => AbrirEditarAsync(context.Item))" />
                </MudTooltip>

                <MudTooltip Text="Excluir fornecedor">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => ExcluirAsync(context.Item))" />
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>

    <NoRecordsContent>
        <MudText Class="pa-4" Color="Color.Secondary">
            Nenhum fornecedor encontrado.
        </MudText>
    </NoRecordsContent>

    <LoadingContent>
        <MudText Class="pa-4" Color="Color.Secondary">
            Carregando fornecedores...
        </MudText>
    </LoadingContent>

    <PagerContent>
        <MudDataGridPager T="Fornecedor" />
    </PagerContent>
</MudDataGrid>

@code {
    private List<Fornecedor> _fornecedores = new();
    private bool _carregando = true;

    private string _busca = string.Empty;

    private IEnumerable<Fornecedor> _fornecedoresFiltrados => string.IsNullOrWhiteSpace(_busca)
        ? _fornecedores
        : _fornecedores.Where(f =>
            (f.RazaoSocial?.Contains(_busca, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (f.CNPJ?.Contains(_busca, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (f.Email?.Contains(_busca, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (f.Telefone?.Contains(_busca, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        try
        {
            _carregando = true;
            _fornecedores = await fornecedorService.ListarTodasFornecedor();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao listar os fornecedores: {ex.Message}", Severity.Error);
        }
        finally
        {
            _carregando = false;
        }
    }
    private readonly DialogOptions _dialogOptions = new DialogOptions
    {
        CloseButton = true,
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        BackdropClick = false

    };

    private async Task AbrirNovoAsync()
    {
        var parameters = new DialogParameters<FornecedorDialog>
  {
     { x => x.Fornecedor, new Fornecedor { Ativo = true } }
  };

        var dialog = await dialogService.ShowAsync<FornecedorDialog>(
            "Novo Fornecedor",
            parameters,
            _dialogOptions);

        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await CarregarAsync();
        }
    }
    private async Task AbrirEditarAsync(Fornecedor fornecedor)
    {
        var FornecedorEdit = await fornecedorService.PesquisarFornecedorPorId(fornecedor.Id);
        if (FornecedorEdit is null)
        {
            Snackbar.Add("Fornecedor não encontrado.", Severity.Error);
            return;
        }
        var parameters = new DialogParameters<FornecedorDialog>
{
    {
        x =>x.Fornecedor, FornecedorEdit
    }
};

        var dialog = await dialogService.ShowAsync<FornecedorDialog>(
         "Editar Fornecedor",
         parameters,
         _dialogOptions);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await CarregarAsync();
        }
    }
    private async Task ExcluirAsync(Fornecedor fornecedor)
    {
        var confirmar = await dialogService.ShowMessageBoxAsync(
    title: "Confirmar Exclusão",
    message: $"Deseja realmente excluir este fornecedor?",
    yesText: "Sim, excluir",
    cancelText: "Cancelar");

        if (confirmar != true)
        {
            return;
        }
        try
        {
            var sucesso = await fornecedorService.ExcluirAsync(fornecedor.Id);
            if (sucesso)
            {
                Snackbar.Add("Fornecedor excluído com sucesso", Severity.Success);
                await CarregarAsync();
            }
            else
            {
                Snackbar.Add("Falha ao excluir o registro", Severity.Warning);
            }

        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao excluir o registro: {ex.Message}", Severity.Error);
        }
    }
}